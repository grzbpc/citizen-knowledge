<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} &mdash; Citizen Knowledge</title>
<meta name="description" content="{{ description or "A companion record to The Performance of Obedience." }}">
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
<link rel="icon" href="{{ '/favicon.ico' | url }}">
<link rel="apple-touch-icon" href="{{ '/apple-touch-icon.png' | url }}">
</head>
<body>
<div class="wrap">
  <a class="backlink" href="{{ '/' | url }}">&larr; Back to the Record</a>
  <header class="post-header">
    <div class="mapping-bar">
      <span class="label">Maps to The Performance of Obedience</span>
      Part {{ part }}: {{ partTitle }} &rarr; Chapter {{ chapter }}: {{ chapterTitle }}{% if subheading %} &rarr; {{ subheading }}{% endif %}
    </div>
    {% if deep_read %}<span class="deep-read-badge">Deep Read &mdash; With Manuscript</span>{% endif %}
    <h1>{{ title }}</h1>
    <p class="source-line">{{ source }}</p>
  </header>

  {{ content | safe }}

  <div class="mapping-citation">
    <span class="label">Book reference</span>
    <strong>Part {{ part }}, {{ partTitle }} &middot; Chapter {{ chapter }}, {{ chapterTitle }}{% if subheading %} &middot; {{ subheading }}{% endif %}</strong>
    {% if book_reference %}<p>{{ book_reference }}</p>{% endif %}
  </div>

  <footer>
    {% if deep_read %}
    Source: {{ source }}. No images reproduced. Manuscript quotations from <em>The Performance of Obedience</em> reproduced as brief excerpts for analytical purposes.
    {% else %}
    Source: {{ source }}. No images reproduced. All summaries are original paraphrase.
    {% endif %}
  </footer>
</div>
</body>
</html>
