<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} &mdash; Citizen Knowledge</title>
<meta name="description" content="{{ description or "A companion record to The Performance of Obedience." }}">
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
<div class="wrap">
  <a class="backlink" href="{{ '/' | url }}">&larr; Back to the Record</a>
  <header class="post-header">
    {% if deep_read %}
      <span class="deep-read-badge">Deep Read &mdash; With Manuscript</span>
    {% else %}
      <span class="standard-tag">Standard</span>
    {% endif %}
    <div class="mapping-bar">
      <span class="label">Maps to The Performance of Obedience</span>
      Part {{ part }}: {{ partTitle }} &rarr; Chapter {{ chapter }}: {{ chapterTitle }}{% if subheading %} &rarr; {{ subheading }}{% endif %}
    </div>
    <h1>{{ title }}</h1>
    <p class="source-line">{{ source }}</p>
  </header>
  {{ content | safe }}
  <div class="mapping-citation">
    <span class="label">Book reference</span>
    <strong>Part {{ part }}, {{ partTitle }} &middot; Chapter {{ chapter }}, {{ chapterTitle }}{% if subheading %} &middot; {{ subheading }}{% endif %}</strong>
    {% if book_reference %}<p class="book-reference-note">{{ book_reference }}</p>{% endif %}
  </div>
  <footer>
    {% if deep_read %}Source: {{ source }}. No images reproduced. Manuscript quotations from <em>The Performance of Obedience</em>, by Greg Lewis, reproduced here as short excerpts for analytical purposes.{% else %}Source: {{ source }}. No images or verbatim text reproduced; summary is original paraphrase.{% endif %}
  </footer>
</div>
</body>
</html>
