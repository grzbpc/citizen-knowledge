<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} &mdash; Citizen Knowledge</title>
<meta name="description" content="{{ description or "A companion record to The Performance of Obedience." }}">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="wrap">
  <a class="backlink" href="/">&larr; Citizen Knowledge</a>
  <header class="post-header">
    <div class="mapping-bar">
      <span class="label">Maps to The Performance of Obedience</span>
      Part {{ part }}: {{ partTitle }} &rarr; Chapter {{ chapter }}: {{ chapterTitle }}{% if subheading %} &rarr; {{ subheading }}{% endif %}
    </div>
    <h1>{{ title }}</h1>
    <p class="source-line">{{ source }}</p>
  </header>

  {{ content | safe }}

  <div class="mapping-citation">
    <span class="label">Book reference</span>
    <strong>Part {{ part }}, {{ partTitle }} &middot; Chapter {{ chapter }}, {{ chapterTitle }}{% if subheading %} &middot; {{ subheading }}{% endif %}</strong>
  </div>

  <footer>
    Source: {{ source }}. No images or verbatim text reproduced; summary is original paraphrase.
  </footer>
</div>
</body>
</html>
