---
permalink: /chapters/index.html
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Browse by Chapter &mdash; Citizen Knowledge</title>
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
<div class="wrap">
  <a class="backlink" href="{{ '/' | url }}">&larr; Back to the Record</a>
  <header class="masthead">
    <h1 class="title" style="font-size:34px;">Browse by Chapter</h1>
    <p class="strapline">Every entry, grouped by which part of the book it maps to.</p>
  </header>

  <main>
    {% set posts = collections.posts %}
    {% set chapterNums = [] %}
    {% for post in posts %}
      {% if post.data.chapter not in chapterNums %}
        {% set chapterNums = (chapterNums.push(post.data.chapter), chapterNums) %}
      {% endif %}
    {% endfor %}

    {% for num in chapterNums | sort %}
      <div class="chapter-group">
        <h2>Chapter {{ num }}</h2>
        {% for post in posts %}
          {% if post.data.chapter == num %}
          <article class="entry index-entry">
            <span class="stamp">
              <span class="label">Maps to The Performance of Obedience</span>
              Part {{ post.data.part }}: {{ post.data.partTitle }} &rarr; Chapter {{ post.data.chapter }}: {{ post.data.chapterTitle }}{% if post.data.subheading %} &rarr; {{ post.data.subheading }}{% endif %}
            </span>
            <h3>
              {% if post.data.deep_read %}<span class="deep-read-badge">Deep Read &mdash; With Manuscript</span>{% endif %}
              <a href="{{ post.url | url }}">{{ post.data.title }}</a>
            </h3>
            <p class="source-line">{{ post.data.source }}</p>
            <p class="dek">{{ post.data.description }}</p>
          </article>
          {% endif %}
        {% endfor %}
      </div>
    {% endfor %}
  </main>

  <footer>
    <p>&copy; Greg Lewis 2026</p>
  </footer>
</div>
</body>
</html>
