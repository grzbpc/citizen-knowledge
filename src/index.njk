<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Citizen Knowledge</title>
<meta name="description" content="A daily record of ordinary news stories mapped against The Performance of Obedience.">
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
<link rel="icon" href="{{ '/favicon.ico' | url }}">
<link rel="apple-touch-icon" href="{{ '/apple-touch-icon.png' | url }}">
</head>
<body>
<header class="masthead">
  <div class="wrap">
    <p class="eyebrow">A companion record to The Performance of Obedience</p>
    <h1 class="title">Citizen Knowledge</h1>
    <p class="strapline">Ordinary news, read one story at a time against the argument of the book: that selective enforcement is not a flaw in modern institutions, but how they actually operate.</p>
    <div class="meta-row">
      <span>{{ collections.posts.length }} ENTRIES</span>
    </div>
  </div>
</header>
<nav class="toc">
  <div class="wrap">
    <a href="{{ '/chapters/' | url }}">Browse by chapter</a>
    <a href="{{ '/about/' | url }}">About this record</a>
  </div>
</nav>
<main>
  <div class="wrap">
    {% set previousDate = "" %}
    {% set dateGroupCount = 0 %}
    {% set signupInserted = false %}
    {% for post in collections.posts %}
    {% set postDateStr = post.data.date | dateStr %}
    {% if postDateStr != previousDate %}
      {% set dateGroupCount = dateGroupCount + 1 %}
      {% if dateGroupCount == 2 and not signupInserted %}
        {% set signupInserted = true %}
        <div class="signup-block" style="margin:36px 0;padding:24px;background:var(--ledger-bg);border-left:5px solid var(--ledger);">
          <p style="font-size:16px;margin:0 0 12px;font-weight:700;">Receive new entries by email</p>
          <p style="font-size:15px;margin:0 0 16px;">New posts are sent out as they're published. You can also follow the <a href="{{ '/feed.xml' | url }}">RSS feed</a> directly.</p>
          <form
            action="https://buttondown.com/api/emails/embed-subscribe/citizenknowledge"
            method="post"
            class="embeddable-buttondown-form"
          >
            <label for="bd-email-home">Email</label>
            <input type="email" name="email" id="bd-email-home" placeholder="you@example.com" style="font-family:Georgia,serif;font-size:15px;padding:8px 10px;border:1px solid var(--ink);width:60%;max-width:280px;" />
            <input type="hidden" value="1" name="embed" />
            <input type="submit" value="Subscribe" style="font-family:'Courier New',monospace;font-size:13px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;padding:9px 16px;background:var(--ink);color:var(--paper);border:none;cursor:pointer;" />
            <p style="font-size:12px;margin-top:10px;">
              <a href="https://buttondown.com" target="_blank" style="color:var(--ink);">Powered by Buttondown.</a>
            </p>
          </form>
        </div>
      {% else %}
        {% if not loop.first %}<hr class="date-divider">{% endif %}
      {% endif %}
      <p class="date-heading">{{ postDateStr }}</p>
      {% set previousDate = postDateStr %}
    {% endif %}
    {% if post.data.layout == "brief-post.njk" %}
    <article class="entry entry--brief">
      <span class="stamp" data-chapter="{{ post.data.chapter }}">
        Part {{ post.data.part }}: {{ post.data.partTitle }} &rarr; Chapter {{ post.data.chapter }}: {{ post.data.chapterTitle }}{% if post.data.subheading %} &rarr; {{ post.data.subheading }}{% endif %}
      </span>
      <h2><a href="{{ post.url | url }}">{{ post.data.title }}</a></h2>
      <p class="source-line">{{ post.data.source }}</p>
      <p class="dek">{{ post.data.description }}</p>
    </article>
    {% else %}
    <article class="entry">
      {% if post.data.deep_read %}
        <span class="deep-read-tag">Deep Read</span>
      {% else %}
        <span class="standard-tag">Standard</span>
      {% endif %}
      <span class="stamp">
        <span class="label">Maps to The Performance of Obedience</span>
        Part {{ post.data.part }}: {{ post.data.partTitle }} &rarr; Chapter {{ post.data.chapter }}: {{ post.data.chapterTitle }}{% if post.data.subheading %} &rarr; {{ post.data.subheading }}{% endif %}
      </span>
      <h2><a href="{{ post.url | url }}">{{ post.data.title }}</a></h2>
      <p class="source-line">{{ post.data.source }}</p>
      <p class="dek">{{ post.data.description }}</p>
    </article>
    {% endif %}
    {% endfor %}
  </div>
</main>
<footer>
  <div class="wrap">
    <p><strong>ABOUT THIS RECORD</strong></p>
    <p>Citizen Knowledge is a companion project to <em>The Performance of Obedience: Legitimacy, Law, and the Systems We Pretend to Believe In</em>, by Greg Lewis. Each entry takes one ordinary news story and maps it against the book's argument: that selective enforcement is not an exception in modern institutions, but the default logic they run on. No images or verbatim text are reproduced from source publications; all summaries are original paraphrase, attributed by publication and date.</p>
    <p>&copy; Greg Lewis 2026</p>
  </div>
</footer>
</body>
</html>
